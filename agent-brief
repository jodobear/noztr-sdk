#!/usr/bin/env bash
set -euo pipefail

if [ -f ./.private-docs/agent-brief ]; then
  exec bash ./.private-docs/agent-brief "$@"
fi

printf '# Agent Brief\n\n'
printf 'Public docs route for `noztr-sdk`.\n\n'
printf '## Read First\n\n'
printf -- '- `README.md`\n'
printf -- '- `docs/INDEX.md`\n'
printf -- '- `examples/README.md`\n'
printf -- '- `CONTRIBUTING.md`\n'
printf '\n'
printf 'If `.private-docs/agent-brief` exists in this clone, use it for internal maintainer work.\n'
